# Database connection
# Mac (default PostgreSQL install via Homebrew):
#   DATABASE_URL="postgresql://yourusername@localhost:5432/taskengine"
# Linux (custom port/socket):
#   DATABASE_URL="postgresql://yourusername@localhost:5433/taskengine?host=/tmp"
# With password:
#   DATABASE_URL="postgresql://user:password@localhost:5432/taskengine"
DATABASE_URL="postgresql://user:password@localhost:5432/taskengine"

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-random-secret"

# Encryption key for Moodle ICS URLs — generate with: openssl rand -hex 32
ENCRYPTION_KEY="generate-a-64-char-hex-string"

PORT=3000

# Groq API key for AI study advice — get one at https://console.groq.com/keys
GROQ_API_KEY=""
